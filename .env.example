# ── Supabase (auth + read + realtime only) ─────────────────────
# Patyna uses the anon key for authentication, RLS-scoped reads,
# and Realtime subscriptions. All task/quest writes go through
# Aelora (see VITE_AELORA_WS_URL below).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Direct Feedback Endpoint ──────────────────────────────────
VITE_FEEDBACK_URL=https://your-project.supabase.co/functions/v1/feedback-direct

# ── ElevenLabs TTS ──────────────────────────────────────────────
VITE_ELEVENLABS_API_KEY=sk_your-elevenlabs-api-key
VITE_ELEVENLABS_VOICE_ID=your-voice-id

# ── Aelora Backend ─────────────────────────────────────────────
VITE_AELORA_WS_URL=wss://your-server/aelora/ws
VITE_AELORA_API_KEY=your-aelora-api-key
VITE_USER_ID=your-user-id
VITE_USERNAME=YourName
VITE_SESSION_ID=patyna-web